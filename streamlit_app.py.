
import streamlit as st
import pandas as pd
import requests
from meteostat import Stations
from datetime import datetime

# 1. Setup Interface
st.set_page_config(page_title="Ensemble Weather Scanner", page_icon="🌤️")
st.title("📊 30-Model Weather Ensemble")
st.markdown("Input a Weather Station (ICAO) to see the spread of 30 GEFS model runs.")

# 2. Station Lookup Logic
station_code = st.text_input("Enter Station ICAO (e.g., KLGA, KLAX, EGLL)", "KLGA").upper()
target_date = st.date_input("Select Forecast Date", datetime.now())

if st.button("Scan Models"):
    # Lookup coordinates for the ICAO code
    stations = Stations()
    stations = stations.identifier('icao', station_code)
    station_data = stations.fetch(1)

    if station_data.empty:
        st.error("Station not found. Please check the ICAO code.")
    else:
        lat = station_data.latitude.iloc[0]
        lon = station_data.longitude.iloc[0]
        st.success(f"Found {station_data.name.iloc[0]} ({lat}, {lon})")

        # 3. Fetch 30 Ensemble Members from Open-Meteo
        # We use the GEFS endpoint which provides 31 ensemble members
        api_url = f"https://ensemble-api.open-meteo.com/v1/ensemble?latitude={lat}&longitude={lon}&models=gefs_seamless&daily=temperature_2m_max&start_date={target_date}&end_date={target_date}&timezone=auto"
        
        response = requests.get(api_url).json()
        
        # Extract all members (typically labeled member00 to member30)
        daily_data = response.get('daily', {})
        temps = [v[0] for k, v in daily_data.items() if 'temperature_2m_max_member' in k]

        if temps:
            # 4. Analytics
            df = pd.DataFrame({"Model Member": [f"Run {i+1}" for i in range(len(temps))], "High Temp": temps})
            avg_temp = np.mean(temps)
            max_temp = np.max(temps)
            min_temp = np.min(temps)
            std_dev = np.std(temps)

            # 5. Visual Display
            col1, col2, col3 = st.columns(3)
            col1.metric("Ensemble Average", f"{avg_temp:.1f}°C")
            col2.metric("Temp Range", f"{min_temp:.1f}° - {max_temp:.1f}°C")
            
            # Probability calculation (Confidence)
            # Low standard deviation = High agreement/probability
            confidence = "High" if std_dev < 1.5 else "Moderate" if std_dev < 3 else "Low"
            col3.metric("Forecast Confidence", confidence)

            st.subheader("Model Distribution")
            st.bar_chart(df.set_index("Model Member"))
            
            with st.expander("See Raw Data from all 30 Models"):
                st.write(df)
        else:
            st.warning("No ensemble data available for this date/location.")

